---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const integrations = [
  { name: 'Claude Code', methodKey: 'claudeMethod' as const, cmd: 'gotk install claude', color: 'border-t-[#d97706]' },
  { name: 'Aider', methodKey: 'aiderMethod' as const, cmd: 'SHELL=gotk aider', color: 'border-t-[#8b5cf6]' },
  { name: 'Cursor', methodKey: 'cursorMethod' as const, cmd: 'SHELL=gotk cursor .', color: 'border-t-accent-blue' },
  { name: 'Continue.dev', methodKey: 'continueMethod' as const, cmd: 'config: shell: gotk -c', color: 'border-t-accent' },
];
---

<section class="py-16 sm:py-24 px-4 sm:px-6 bg-card/50">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-center mb-4">
      {t(locale, 'integrationsTitle')}
    </h2>
    <p class="text-text-muted text-center mb-8 sm:mb-12 text-base sm:text-lg px-2">
      {t(locale, 'integrationsSubtitle')}
    </p>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6">
      {integrations.map((i) => (
        <div class={`p-4 sm:p-6 bg-card rounded-xl border border-text-muted/10 border-t-2 ${i.color}`}>
          <h3 class="text-sm sm:text-lg font-semibold mb-1">{i.name}</h3>
          <p class="text-text-muted text-xs sm:text-sm mb-3 sm:mb-4">{t(locale, i.methodKey)}</p>
          <code class="block px-2 sm:px-3 py-1.5 sm:py-2 bg-base rounded text-[10px] sm:text-sm font-mono text-accent break-all">
            {i.cmd}
          </code>
        </div>
      ))}
    </div>
  </div>
</section>
