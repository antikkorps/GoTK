---
import type { Locale } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const steps = [
  {
    num: '1',
    titleKey: 'step1Title' as const,
    cmd: 'go install github.com/antikkorps/GoTK/cmd/gotk@latest',
  },
  {
    num: '2',
    titleKey: 'step2Title' as const,
    cmd: 'gotk install claude',
    noteKey: 'step2Note' as const,
  },
  {
    num: '3',
    titleKey: 'step3Title' as const,
    cmd: 'gotk grep -rn "TODO" .',
    noteKey: 'step3Note' as const,
  },
];
---

<section class="py-16 sm:py-24 px-4 sm:px-6 bg-card/50">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-center mb-8 sm:mb-12">
      {t(locale, 'quickStartTitle')}
    </h2>

    <div class="relative">
      <!-- Timeline line -->
      <div class="absolute left-5 sm:left-6 top-0 bottom-0 w-px bg-text-muted/20"></div>

      <div class="space-y-8 sm:space-y-10">
        {steps.map((s) => (
          <div class="flex gap-4 sm:gap-6 items-start">
            <div class="w-10 h-10 sm:w-12 sm:h-12 rounded-full bg-accent text-base flex items-center justify-center font-bold text-base sm:text-lg shrink-0 relative z-10">
              {s.num}
            </div>
            <div class="flex-1 pt-1 sm:pt-2 min-w-0 overflow-hidden">
              <h3 class="text-lg sm:text-xl font-semibold mb-2 sm:mb-3">{t(locale, s.titleKey)}</h3>
              <div class="overflow-x-auto rounded-lg border border-text-muted/20">
                <code class="block px-3 sm:px-4 py-2.5 sm:py-3 bg-base font-mono text-xs sm:text-sm whitespace-nowrap">
                  $ {s.cmd}
                </code>
              </div>
              {s.noteKey && <p class="text-text-muted text-xs sm:text-sm mt-2">{t(locale, s.noteKey)}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
