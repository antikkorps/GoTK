---
import type { Locale } from '../i18n/translations';
import { t, getLocalePath } from '../i18n/translations';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const title = t(locale, 'siteTitle');
const description = t(locale, 'siteDescription');
const siteBase = 'https://antikkorps.github.io';
const canonicalPath = getLocalePath(locale);
const canonicalUrl = `${siteBase}${canonicalPath}`;
const ogImage = `${siteBase}/GoTK/og-image.png`;
const altLocale = locale === 'en' ? 'fr' : 'en';
const altPath = getLocalePath(altLocale);
const altUrl = `${siteBase}${altPath}`;
const ogLocale = locale === 'en' ? 'en_US' : 'fr_FR';
const ogLocaleAlt = locale === 'en' ? 'fr_FR' : 'en_US';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'GoTK',
  description: 'LLM Output Proxy — CLI tool that filters command output to reduce token usage by 48-98%.',
  url: `${siteBase}/GoTK/`,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux',
  programmingLanguage: 'Go',
  license: 'https://github.com/antikkorps/GoTK/blob/main/LICENSE',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: 'antikkorps', url: 'https://github.com/antikkorps' },
  codeRepository: 'https://github.com/antikkorps/GoTK',
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Canonical & alternate -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link rel="alternate" hreflang={altLocale} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={`${siteBase}/GoTK/`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:site_name" content="GoTK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/svg+xml" href="/GoTK/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-base text-text-primary antialiased font-sans">
    <!-- Language switcher -->
    <a
      href={altPath}
      class="fixed top-4 right-4 z-50 px-3 py-1.5 bg-card/80 backdrop-blur border border-text-muted/20 rounded-full text-sm text-text-muted hover:text-accent-blue hover:border-accent-blue/30 transition-colors"
    >
      {t(locale, 'langLabel')}
    </a>
    <slot />
  </body>
</html>
