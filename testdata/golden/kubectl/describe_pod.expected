apiVersion: v1
kind: Pod
metadata:
  name: api-server-7f8b9c5d4e-x2k9m
  namespace: production
  managedFields: (omitted)
  annotations:
    kubectl.kubernetes.io/last-applied-configuration: (omitted)
  labels:
    app: api
    pod-template-hash: 7f8b9c5d4e
spec:
  containers:
    - name: api
      image: myregistry.io/api:v2.3.1
      ports:
